# Impulso Jobs — SPA Angular en Apache/cPanel
# Sube el contenido de dist/frontend/browser/ (incluido este .htaccess) a la
# carpeta del dominio (p. ej. public_html/).

RewriteEngine On
RewriteBase /

# Redirige HTTP -> HTTPS (opcional; deja comentado si usas otro método de SSL)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Ruteo del lado del cliente: si el recurso no existe como archivo/carpeta,
# entrega index.html para que Angular resuelva la ruta.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
RewriteRule ^ index.html [L]

# --- Compresión ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

# --- Caché ---
<IfModule mod_headers.c>
  # Los assets llevan hash en el nombre (outputHashing: all) -> caché larga.
  <FilesMatch "\.(js|css|woff2?|ttf|eot|svg|png|jpg|jpeg|gif|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # index.html nunca se cachea, para que un nuevo deploy se tome de inmediato.
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
