# ============================================================
#  Base de datos
# ============================================================
# Motor a usar: "postgres" (desarrollo local) o "mysql" (cPanel).
DB_TYPE=postgres

# --- PostgreSQL (desarrollo local) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=medicore

# --- MySQL (ejemplo para despliegue en cPanel) ---
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USERNAME=cpaneluser_dbuser
# DB_PASSWORD=tu_password_seguro
# DB_NAME=cpaneluser_dbname

# Sincroniza el esquema automáticamente a partir de las entidades.
# Útil en desarrollo; DEBE quedar en "false" en producción (cPanel) -> usa migraciones.
DB_SYNCHRONIZE=false

# ============================================================
#  JWT
# ============================================================
JWT_ACCESS_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_largo_y_aleatorio
JWT_REFRESH_EXPIRES_IN=7d
# Recuperación de contraseña (M3). Si se omiten, cae en JWT_ACCESS_SECRET / 30m.
JWT_RESET_SECRET=cambia_esto_por_otro_secreto_largo_y_aleatorio
JWT_RESET_EXPIRES_IN=30m
# Verificación de correo (M4). Si se omiten, cae en JWT_ACCESS_SECRET / 30m.
JWT_VERIFY_SECRET=cambia_esto_por_otro_secreto_largo_y_aleatorio
JWT_VERIFY_EXPIRES_IN=30m

# ============================================================
#  App
# ============================================================
# PORT=3000
# URL del frontend, base de los magic links (recuperación y verificación).
APP_WEB_URL=http://localhost:4200
